# ─── Backend ──────────────────────────────────────────────────────────────────
# Get a free API key at https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Your GCP project ID (must have Firestore + Cloud Run enabled)
GCP_PROJECT_ID=your-gcp-project-id

# Optional: path to service account JSON for Firestore auth
# Leave empty to use `gcloud auth application-default login`
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Data source: local (no Firestore needed) or firestore
GRAPH_SOURCE=local

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
